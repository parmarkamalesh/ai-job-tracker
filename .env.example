# Copy to `.env` for `docker compose`. MySQL runs on your machine (database: aijobtracker).

DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=aijobtracker

# If DB_PASSWORD contains `$`, in this file use `$$` for a literal dollar when Compose expands vars,
# e.g. ...#$  →  ...#$$

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
JWT_SECRET=
