PORT=3001
NODE_ENV=development

# Recommended: separate vars (safe for special characters in DB_PASSWORD)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=aijobtracker

# Alternative: single URL (password must be URL-encoded, e.g. @ → %40, # → %23, $ → %24)
# DATABASE_URL=mysql://root:encoded_password@localhost:3306/aijobtracker

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
AI_SERVICE_URL=http://localhost:8000
